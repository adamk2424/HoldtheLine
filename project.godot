; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Hold the Line"
config/description="RTS / Tower Defense hybrid. Survive as long as possible."
run/main_scene="res://ui/menus/main_menu.tscn"
config/features=PackedStringArray("4.6")

[autoload]

FrameBudget="*res://autoloads/frame_budget.gd"
GameBus="*res://autoloads/game_bus.gd"
GameData="*res://autoloads/game_data.gd"
GameState="*res://autoloads/game_state.gd"
AudioManager="*res://autoloads/audio_manager.gd"
AudioDebugOverlay="*res://autoloads/audio_debug_overlay.gd"
EntityRegistry="*res://autoloads/entity_registry.gd"
MetaProgress="*res://autoloads/meta_progress.gd"
VfxManager="*res://autoloads/vfx_manager.gd"
VfxSystem="*res://autoloads/vfx_system.gd"
LevelSystem="*res://systems/level_system.gd"
ItemSystem="*res://systems/item_system.gd"
ProgressionTracker="*res://systems/progression_tracker.gd"
AchievementSystem="*res://systems/achievement_system.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="Hold the Line"

